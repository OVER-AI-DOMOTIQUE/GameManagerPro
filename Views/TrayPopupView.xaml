<UserControl x:Class="GameManagerPro.Views.TrayPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="380" MaxHeight="500" Background="Transparent"
             TextElement.Foreground="White">
    <Border Background="#14171A" CornerRadius="8" BorderBrush="#24292E" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="15,15,15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Source="/Assets/appicon.ico" Width="18" Height="18" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Game Manager Pro" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}" Width="24" Height="24" Padding="0" Click="Close_Click">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#8B949E" />
                </Button>
            </Grid>

            <!-- Game List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15,10" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1C1F23"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="70" Height="33" CornerRadius="4" Margin="0,0,15,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}" Width="30" Height="30" Padding="0" Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Play" Width="20" Height="20" Foreground="#3B82F6"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#1C1F23" CornerRadius="0,0,8,8" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ouvrir l'application complète" Foreground="#8B949E" FontSize="12" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="OpenApp_Click" />
                    <TextBlock Grid.Column="1" Text="Quitter" Foreground="#EF4444" FontSize="12" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="Exit_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
