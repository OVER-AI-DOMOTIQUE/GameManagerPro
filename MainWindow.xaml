<Window x:Class="GameManagerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Game Manager Pro" Height="750" Width="1200"
        Icon="Assets/appicon.ico"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#18181B" BorderBrush="#27272A" BorderThickness="0 0 1 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ControllerClassic" Width="42" Height="42" Foreground="#8B5CF6" VerticalAlignment="Center" Margin="0 0 16 0"/>
                    <TextBlock Text="Game Manager" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="16 0">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="56" HorizontalContentAlignment="Left" Padding="20 0" Margin="0 4" Background="#27272A">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Library" Width="24" Height="24" Margin="0 0 16 0" Foreground="#A78BFA"/>
                            <TextBlock Text="Ma Bibliothèque" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ScanDirectoryCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#A1A1AA" Height="56" HorizontalContentAlignment="Left" Padding="20 0" Margin="0 4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MagnifyScan" Width="24" Height="24" Margin="0 0 16 0"/>
                            <TextBlock Text="Lancer un Scan" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Settings Button Bottom -->
                <Button Grid.Row="2" Click="Settings_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#A1A1AA" Height="64" HorizontalContentAlignment="Left" Padding="32 0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Settings" Width="24" Height="24" Margin="0 0 16 0"/>
                        <TextBlock Text="Paramètres" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#09090B">
            <!-- Header -->
            <Border Height="120" VerticalAlignment="Top" BorderBrush="#27272A" BorderThickness="0 0 0 1">
                <Grid>
                    <TextBlock Text="Ma Bibliothèque" FontSize="36" FontWeight="Bold" Margin="48 0 0 0" VerticalAlignment="Center" Foreground="White"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 0 48 0" Visibility="{Binding IsNotEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Trier par :" VerticalAlignment="Center" Margin="0 0 16 0" Foreground="#A1A1AA" FontSize="16"/>
                        <ComboBox SelectedValuePath="Content" SelectedValue="{Binding SelectedSort}" Width="120" FontSize="16" Foreground="White">
                            <ComboBoxItem Content="A-Z" />
                            <ComboBoxItem Content="Z-A" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Margin="0 120 0 0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="Ghost" Width="120" Height="120" Foreground="#27272A" HorizontalAlignment="Center" Margin="0 0 0 24"/>
                    <TextBlock Text="Aucun jeu configuré ou trouvé." FontSize="24" FontWeight="SemiBold" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0 0 0 8"/>
                    <TextBlock Text="Cliquez sur 'Lancer un Scan' ou vérifiez vos Paramètres." FontSize="16" Foreground="#71717A" HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Margin="32" Visibility="{Binding IsNotEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding GamesView}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Width="220" Margin="16" materialDesign:ElevationAssist.Elevation="Dp4" Background="#18181B" UniformCornerRadius="12">
                                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Retenter de récupérer l'image" Command="{Binding PlacementTarget.Tag.FetchGridCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                                <Separator />
                                                <MenuItem Header="Supprimer (Retirer de la liste)" Command="{Binding PlacementTarget.Tag.RemoveGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Exclure (Ignorer au prochain scan)" Command="{Binding PlacementTarget.Tag.ExcludeGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="300" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Game Image -->
                                        <Grid ClipToBounds="True">
                                            <Rectangle Fill="#27272A" />
                                            <materialDesign:PackIcon Kind="ImageBroken" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3F3F46"/>
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            
                                            <!-- Hover Overlay -->
                                            <Grid Background="#99000000" Opacity="0" Name="Overlay">
                                                <Button Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                                                        Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Width="64" Height="64"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Play" Width="32" Height="32" />
                                                </Button>
                                            </Grid>
                                        </Grid>
                                        
                                        <!-- Game Title -->
                                        <Border Grid.Row="1" Padding="16 20">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                    <materialDesign:Card.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </materialDesign:Card.Triggers>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
        
        <!-- Snackbar at the bottom of the window -->
        <materialDesign:Snackbar MessageQueue="{Binding MainSnackbarMessageQueue}" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" />
    </Grid>
</Window>
